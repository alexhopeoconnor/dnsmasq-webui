    private void OpenLeasesSettings() => SettingsModalService.Open(SettingsModalContext.LeasesPolling, "Leases refresh interval");

    private async void OnSettingsChanged()
    {
        await InvokeAsync(() =>
        {
            _leasesRefreshIntervalSeconds = ClientSettingsFields.LeasesPollingInterval.Value;
            if (_status != null && _status.LeasesPathConfigured)
                StartLeasesRefreshTimer();
            StateHasChanged();
        });
    }

    private void StartLeasesRefreshTimer()
    {
        _leasesRefreshTimer?.Dispose();
        _leasesRefreshTimer = new Timer(
            _ => _ = InvokeAsync(OnLeasesRefreshTick),
            null,
            TimeSpan.FromSeconds(_leasesRefreshIntervalSeconds),
            TimeSpan.FromSeconds(_leasesRefreshIntervalSeconds));
    }

    private async Task OnLeasesRefreshTick()
    {
        if (_status == null || !_status.LeasesPathConfigured) return;
        await LoadLeases(showLoading: false);
        RefreshStaticHostsFromSession();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadLeases(bool showLoading = true, bool forceRefresh = false)
    {
        if (_status == null || !_status.LeasesPathConfigured) return;
        if (showLoading) _leasesLoading = true;
        try
        {
            var resp = await LeasesClient.GetLeasesAsync(forceRefresh: forceRefresh);
            _leases = resp.Entries;
        }
        finally
        {
            if (showLoading) _leasesLoading = false;
        }
    }

    private async Task Reload()
    {
        _saving = true;
        _error = null;
        _message = null;
        try
        {
            var result = await ReloadClient.ReloadAsync();
            if (result.Success)
                _message = "Dnsmasq reloaded.";
            else
                _error = "Reload failed: " + (result.StdErr ?? "unknown");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        Session.Changed -= OnSessionChanged;
        SettingsModalService.SettingsChanged -= OnSettingsChanged;
        _leasesRefreshTimer?.Dispose();
        _leasesRefreshTimer = null;
        var module = _tableScrollCueModule;
        _tableScrollCueModule = null;
        if (module != null)
            await module.DisposeAsyncSafe();
    }
}
