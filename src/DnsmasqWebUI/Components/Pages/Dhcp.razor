    private void RemoveOptionAt(int index)
    {
        if (_status == null) return;
        var field = _optionUseForce ? DhcpOptionForceField : DhcpOptionField;
        var list = PageEditor.GetEffectiveMultiValues(_status, field).ToList();
        if (index < 0 || index >= list.Count) return;
        list.RemoveAt(index);
