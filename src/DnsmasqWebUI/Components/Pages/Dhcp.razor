    private void BeginEditRange(int index)
    {
        var list = RangeStrings.ToList();
        if (index < 0 || index >= list.Count) return;
        var raw = list[index];
        var draft = DhcpRangeDraft.FromRaw(raw);
        _editingRangeIndex = index;
        if (!draft.IsStructured)
        {
            _rangeEditRaw = raw;
            _rangeEditTags = "";
            _rangeEditStart = "";
            _rangeEditSecond = "";
            _rangeEditRemaining = "";
        }
        else
        {
            _rangeEditRaw = "";
            _rangeEditTags = string.Join(',', draft.Tags);
            _rangeEditStart = draft.StartToken;
            _rangeEditSecond = draft.SecondToken;
            _rangeEditRemaining = string.Join(',', draft.RemainingTokens);
        }
    }

    private void CancelRangeEdit() => _editingRangeIndex = null;

    private void CommitRangeEdit()
    {
        if (_status == null || _editingRangeIndex is not { } idx) return;
        var list = RangeStrings.ToList();
        if (idx < 0 || idx >= list.Count) return;

        var original = DhcpRangeDraft.FromRaw(list[idx]);
        var newValue = !original.IsStructured ? _rangeEditRaw.Trim() : BuildRangeFromFields();

        if (string.IsNullOrWhiteSpace(newValue))
            return;

        list[idx] = newValue;
        PageEditor.ReplaceMultiValues(_status, DhcpRangeField, list);
        _editingRangeIndex = null;
        PageEditor.RefreshCrossOptionIssues(_status);
        StateHasChanged();
    }

    private string BuildRangeFromFields()
    {
        var tags = string.IsNullOrWhiteSpace(_rangeEditTags)
            ? Array.Empty<string>()
            : _rangeEditTags.Split(',').Select(t => t.Trim()).Where(t => t.Length > 0).ToArray();
        var parts = new List<string>();
        parts.AddRange(tags);
        parts.Add(_rangeEditStart.Trim());
        parts.Add(_rangeEditSecond.Trim());
        if (!string.IsNullOrWhiteSpace(_rangeEditRemaining))
            parts.AddRange(_rangeEditRemaining.Split(',').Select(t => t.Trim()).Where(t => t.Length > 0));
        return string.Join(',', parts);
    }

    private void RemoveRangeAt(int index)
    {
        if (_status == null) return;
        var list = RangeStrings.ToList();
        if (index < 0 || index >= list.Count) return;
        list.RemoveAt(index);
        PageEditor.ReplaceMultiValues(_status, DhcpRangeField, list);
        if (_editingRangeIndex is { } editIdx)
        {
            if (editIdx == index)
                _editingRangeIndex = null;
            else if (editIdx > index)
                _editingRangeIndex = editIdx - 1;
        }
        PageEditor.RefreshCrossOptionIssues(_status);
        StateHasChanged();
    }

