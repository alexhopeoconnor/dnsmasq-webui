    private void AppendOptionFromPreset()
    {
        if (_status == null) return;
        var preset = DhcpOptionPresets.All.FirstOrDefault(p => p.Key == _optionPresetKey) ?? DhcpOptionPresets.All[0];
        var prefixes = string.IsNullOrWhiteSpace(_optionPrefix)
            ? Array.Empty<string>()
            : _optionPrefix.Split(',').Select(s => s.Trim()).Where(s => s.Length > 0).ToArray();
        var vals = string.IsNullOrWhiteSpace(_optionValues)
            ? preset.DefaultValues.ToList()
            : _optionValues.Split(',').Select(s => s.Trim()).Where(s => s.Length > 0).ToList();
        var draft = new DhcpOptionDraft
        {
            PrefixTokens = prefixes,
            Selector = preset.Selector,
            ValueTokens = vals
        };
        var field = _optionUseForce ? DhcpOptionForceField : DhcpOptionField;
        PageEditor.AppendMultiValue(_status, field, draft.ToRaw());
        PageEditor.Activate(field);
        StateHasChanged();
    }

    private void AppendCustomOption()
