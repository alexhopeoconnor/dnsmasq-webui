@page "/filters"
@rendermode InteractiveServer
@namespace DnsmasqWebUI.Components.Pages
@using DnsmasqWebUI.Models.Dnsmasq.EffectiveConfig
@using DnsmasqWebUI.Infrastructure.Services.EffectiveConfig.Abstractions
@using DnsmasqWebUI.Infrastructure.Services.EffectiveConfig.Metadata
@inject IStatusClient StatusClient
@inject IEffectiveConfigPageEditor PageEditor
@inject IOptions<ApplicationOptions> AppOptions

<PageTitle>Filters | @AppTitle</PageTitle>

<h1 class="page-title">Filters Configuration</h1>

@if (_status == null)
{
    <p class="d-flex align-items-center gap-2">
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        Loading...
    </p>
}
else
{
    <section class="page-section">
        <EffectiveConfigSection Status="_status" Context="EffectiveConfigContext.Filters" ShowSearchBox="true" OnSaveCompleted="RefreshStatusAsync" />
    </section>
    <section class="page-section">
        <h2 class="page-section-title">Quick add</h2>
        <div class="d-flex flex-wrap gap-3 align-items-end">
            <div class="d-flex flex-wrap gap-2 align-items-end">
                <input class="form-control form-control-sm" style="width:14rem" placeholder="Domain to block (e.g. ads.example.com)" @bind="_blockDomain" />
                <button type="button" class="btn btn-sm btn-primary" @onclick="BlockDomain">Block domain</button>
            </div>
            <div class="d-flex flex-wrap gap-2 align-items-end">
                <input class="form-control form-control-sm" style="width:12rem" placeholder="Domain (e.g. internal.local)" @bind="_splitDomain" />
                <input class="form-control form-control-sm" style="width:10rem" placeholder="Upstream (e.g. 10.0.0.1)" @bind="_splitUpstream" />
                <button type="button" class="btn btn-sm btn-primary" @onclick="AddSplitDnsRoute">Split DNS route</button>
            </div>
            <div class="d-flex flex-wrap gap-2 align-items-end">
                <input class="form-control form-control-sm" style="width:14rem" placeholder="Domain (local only, e.g. lan)" @bind="_localDomain" />
                <button type="button" class="btn btn-sm btn-primary" @onclick="AddLocalOnlyDomain">Local-only domain</button>
            </div>
        </div>
        @if (_filterError != null)
        {
            <p class="text-danger small mt-2 mb-0">@_filterError</p>
        }
    </section>
    <div class="page-chips" role="group" aria-label="Filter policy category">
        <span class="page-chip active">All</span>
        <span class="page-chip">Blocking / sinkhole</span>
        <span class="page-chip">Split DNS</span>
        <span class="page-chip">Safety</span>
        <span class="page-chip">Response shaping</span>
        <span class="page-chip">Firewall</span>
    </div>
}

@code {
    private string AppTitle => AppOptions!.Value!.EffectiveTitle;
    private DnsmasqServiceStatus? _status;
    private string _blockDomain = "";
    private string _splitDomain = "";
    private string _splitUpstream = "";
    private string _localDomain = "";
    private string? _filterError;

    private void BlockDomain()
    {
        _filterError = null;
        var domain = _blockDomain?.Trim() ?? "";
        if (string.IsNullOrEmpty(domain))
        {
            _filterError = "Enter a domain to block.";
            return;
        }
        var field = PageEditor.Field(EffectiveConfigSections.SectionResolver, DnsmasqConfKeys.Address);
        var current = PageEditor.GetEffectiveMultiValues(_status!, field);
        var rule = $"/{domain}/#";
        var next = current.Contains(rule, StringComparer.OrdinalIgnoreCase) ? current.ToList() : current.Append(rule).ToList();
        PageEditor.ReplaceMultiValues(_status!, field, next);
        PageEditor.Activate(field);
        _blockDomain = "";
        StateHasChanged();
    }

    private void AddSplitDnsRoute()
    {
        _filterError = null;
        var domain = _splitDomain?.Trim() ?? "";
        var upstream = _splitUpstream?.Trim() ?? "";
        if (string.IsNullOrEmpty(domain) || string.IsNullOrEmpty(upstream))
        {
            _filterError = "Domain and upstream are required.";
            return;
        }
        var field = PageEditor.Field(EffectiveConfigSections.SectionResolver, DnsmasqConfKeys.Server);
        var current = PageEditor.GetEffectiveMultiValues(_status!, field);
        var rule = $"/{domain}/{upstream}";
        var next = current.Append(rule).ToList();
        PageEditor.ReplaceMultiValues(_status!, field, next);
        PageEditor.Activate(field);
        _splitDomain = "";
        _splitUpstream = "";
        StateHasChanged();
    }

    private void AddLocalOnlyDomain()
    {
        _filterError = null;
        var domain = _localDomain?.Trim() ?? "";
        if (string.IsNullOrEmpty(domain))
        {
            _filterError = "Enter a domain.";
            return;
        }
        var field = PageEditor.Field(EffectiveConfigSections.SectionResolver, DnsmasqConfKeys.Local);
        var current = PageEditor.GetEffectiveMultiValues(_status!, field);
        var rule = $"/{domain}/";
        var next = current.Contains(rule, StringComparer.OrdinalIgnoreCase) ? current.ToList() : current.Append(rule).ToList();
        PageEditor.ReplaceMultiValues(_status!, field, next);
        PageEditor.Activate(field);
        _localDomain = "";
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task RefreshStatusAsync()
    {
        try
        {
            _status = await StatusClient.GetStatusAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch { /* ignore */ }
    }

    private async Task Load()
    {
        try
        {
            _status = await StatusClient.GetStatusAsync();
        }
        catch
        {
            // Status will stay null; UI shows loading or empty
        }
    }
}
