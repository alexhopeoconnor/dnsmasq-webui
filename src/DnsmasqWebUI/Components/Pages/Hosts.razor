    private void OnManagedRowClick(HostsPageRow row, MouseEventArgs e)
    {
        DeactivateEffectiveConfigFieldIfActive();
        if (!row.IsEditable || IsInlineEditing)
            return;

        // Second (and third) click of a multi-click fires click with Detail > 1; skip so double-click does not toggle selection before edit.
        if (e.Detail > 1)
            return;

        if (e.ShiftKey)
        {
            ApplyShiftManagedSelection(row);
            StateHasChanged();
            return;
        }

        if (e.CtrlKey || e.MetaKey)
        {
            if (!_selectedManagedRowIds.Add(row.Id))
                _selectedManagedRowIds.Remove(row.Id);
            _selectionAnchorRowId = row.Id;
        }
        else if (_selectedManagedRowIds.Contains(row.Id))
        {
            _selectedManagedRowIds.Remove(row.Id);
            _selectionAnchorRowId = _selectedManagedRowIds.Count == 1 ? _selectedManagedRowIds.First() : null;
        }
        else
        {
            _selectedManagedRowIds.Clear();
            _selectedManagedRowIds.Add(row.Id);
            _selectionAnchorRowId = row.Id;
        }

        StateHasChanged();
    }

    private List<string> GetManagedEditableRowOrder()
    {
        var ids = new List<string>();
        foreach (var g in VisibleGroups)
        {
            if (!IsManagedEditableGroup(g))
                continue;
            foreach (var r in g.Rows)
            {
                if (r.IsEditable)
                    ids.Add(r.Id);
            }
        }

        return ids;
    }

    private void ApplyShiftManagedSelection(HostsPageRow row)
    {
        var order = GetManagedEditableRowOrder();
        var idxRow = order.IndexOf(row.Id);
        if (idxRow < 0)
            return;

        if (string.IsNullOrEmpty(_selectionAnchorRowId))
        {
            _selectedManagedRowIds.Clear();
            _selectedManagedRowIds.Add(row.Id);
            _selectionAnchorRowId = row.Id;
            return;
        }

        var idxAnchor = order.IndexOf(_selectionAnchorRowId);
        if (idxAnchor < 0)
        {
            _selectedManagedRowIds.Clear();
            _selectedManagedRowIds.Add(row.Id);
            _selectionAnchorRowId = row.Id;
            return;
        }

        var lo = Math.Min(idxAnchor, idxRow);
        var hi = Math.Max(idxAnchor, idxRow);
        _selectedManagedRowIds.Clear();
        for (var i = lo; i <= hi; i++)
            _selectedManagedRowIds.Add(order[i]);
    }

