    private Task OpenRemoveHostsModalAsync()
    {
        if (_status == null || string.IsNullOrWhiteSpace(_status.ManagedHostsFilePath) || IsInlineEditing || ManagedSelectionCount == 0)
            return Task.CompletedTask;
        _removeModalSelectionCount = ManagedSelectionCount;
        _showRemoveHostsModal = true;
