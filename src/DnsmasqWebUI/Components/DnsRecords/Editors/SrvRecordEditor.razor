@using DnsmasqWebUI.Infrastructure.Services.EffectiveConfig.Metadata
<h4 class="h6 mb-2">SRV (srv-host)</h4>
<div class="row g-2 align-items-end">
    <div class="col-md-3">
        <label class="form-label small mb-0">Service (_service._proto[.name])</label>
        <input class="form-control form-control-sm" @bind="_svc" @bind:event="oninput" />
    </div>
    <div class="col-md-2">
        <label class="form-label small mb-0">Target</label>
        <input class="form-control form-control-sm" @bind="_target" @bind:event="oninput" placeholder="optional" />
    </div>
    <div class="col-md-1">
        <label class="form-label small mb-0">Port</label>
        <input class="form-control form-control-sm" type="number" min="0" max="65535" @bind="_port" @bind:event="oninput" />
    </div>
    <div class="col-md-1">
        <label class="form-label small mb-0">Pri</label>
        <input class="form-control form-control-sm" type="number" min="0" max="65535" @bind="_pri" @bind:event="oninput" />
    </div>
    <div class="col-md-1">
        <label class="form-label small mb-0">Wt</label>
        <input class="form-control form-control-sm" type="number" min="0" max="65535" @bind="_wt" @bind:event="oninput" />
    </div>
    <div class="col-md-4 d-flex gap-1">
        <button type="button" class="btn btn-sm btn-primary" @onclick="SaveAsync">Save</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="OnCancel">Cancel</button>
    </div>
</div>
@if (_error != null)
{
    <p class="text-danger small mt-2 mb-0">@_error</p>
}

@code {
    [Parameter] public DnsRecordRow? Existing { get; set; }
    [Parameter] public EventCallback<DnsRecordEditorResult> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private string _svc = "";
    private string _target = "";
    private string _port = "";
    private string _pri = "";
    private string _wt = "";
    private string? _error;
    private string? _boundRowKey;

    protected override void OnParametersSet()
    {
        if (!DnsRecordEditorSyncGuard.ShouldReseedFromExisting(ref _boundRowKey, Existing))
            return;

        if (Existing?.Payload is SrvPayload p)
        {
            _svc = p.ServiceName;
            _target = p.Target ?? "";
            _port = p.Port?.ToString() ?? "";
            _pri = p.Priority?.ToString() ?? "";
            _wt = p.Weight?.ToString() ?? "";
        }
        else
        {
            _svc = "";
            _target = "";
            _port = "";
            _pri = "";
            _wt = "";
        }

        _error = null;
    }

    private async Task SaveAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_svc))
        {
            _error = "Service name is required.";
            return;
        }

        int? port = null;
        int? pri = null;
        int? wt = null;
        if (!string.IsNullOrWhiteSpace(_port) || !string.IsNullOrWhiteSpace(_pri) || !string.IsNullOrWhiteSpace(_wt))
        {
            if (!int.TryParse(string.IsNullOrWhiteSpace(_port) ? "0" : _port, out var po) || po is < 0 or > 65535)
            {
                _error = "Port must be 0–65535.";
                return;
            }

            if (!int.TryParse(string.IsNullOrWhiteSpace(_pri) ? "0" : _pri, out var pr) || pr is < 0 or > 65535)
            {
                _error = "Priority must be 0–65535.";
                return;
            }

            if (!int.TryParse(string.IsNullOrWhiteSpace(_wt) ? "0" : _wt, out var w) || w is < 0 or > 65535)
            {
                _error = "Weight must be 0–65535.";
                return;
            }

            port = po;
            pri = pr;
            wt = w;
        }

        var tgt = string.IsNullOrWhiteSpace(_target) ? null : _target.Trim();
        var payload = new SrvPayload(_svc.Trim(), tgt, port, pri, wt);
        var isNew = Existing == null;
        var row = isNew
            ? new DnsRecordRow(
                Id: $"{DnsmasqConfKeys.Srv}:new",
                OccurrenceId: $"{DnsmasqConfKeys.Srv}:new",
                OptionName: DnsmasqConfKeys.Srv,
                Family: DnsRecordFamily.Srv,
                IndexInOption: -1,
                RawValue: "",
                Source: null,
                SourcePath: null,
                SourceLabel: null,
                IsDraftOnly: false,
                IsEditable: true,
                Payload: payload,
                Issues: [],
                Summary: "")
            : Existing! with { Payload = payload };

        await OnSave.InvokeAsync(new DnsRecordEditorResult(row, isNew));
    }
}
