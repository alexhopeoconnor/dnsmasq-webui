@using DnsmasqWebUI.Infrastructure.Services.EffectiveConfig.Metadata
<h4 class="h6 mb-2">MX</h4>
<div class="row g-2 align-items-end">
    <div class="col-md-3">
        <label class="form-label small mb-0">Domain</label>
        <input class="form-control form-control-sm" @bind="_domain" @bind:event="oninput" />
    </div>
    <div class="col-md-3">
        <label class="form-label small mb-0">Mail host</label>
        <input class="form-control form-control-sm" @bind="_host" @bind:event="oninput" placeholder="optional" />
    </div>
    <div class="col-md-2">
        <label class="form-label small mb-0">Preference</label>
        <input class="form-control form-control-sm" type="number" min="0" max="65535" @bind="_pref" @bind:event="oninput" placeholder="optional" />
    </div>
    <div class="col-md-4 d-flex gap-1">
        <button type="button" class="btn btn-sm btn-primary" @onclick="SaveAsync">Save</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="OnCancel">Cancel</button>
    </div>
</div>
@if (_error != null)
{
    <p class="text-danger small mt-2 mb-0">@_error</p>
}

@code {
    [Parameter] public DnsRecordRow? Existing { get; set; }
    [Parameter] public EventCallback<DnsRecordEditorResult> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private string _domain = "";
    private string _host = "";
    private string _pref = "";
    private string? _error;
    private string? _boundRowKey;

    protected override void OnParametersSet()
    {
        if (!DnsRecordEditorSyncGuard.ShouldReseedFromExisting(ref _boundRowKey, Existing))
            return;

        if (Existing?.Payload is MxPayload p)
        {
            _domain = p.Domain;
            _host = p.Hostname ?? "";
            _pref = p.Preference?.ToString() ?? "";
        }
        else
        {
            _domain = "";
            _host = "";
            _pref = "";
        }

        _error = null;
    }

    private async Task SaveAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_domain))
        {
            _error = "Domain is required.";
            return;
        }

        int? pref = null;
        if (!string.IsNullOrWhiteSpace(_pref))
        {
            if (!int.TryParse(_pref, out var p) || p is < 0 or > 65535)
            {
                _error = "Preference must be 0–65535.";
                return;
            }

            pref = p;
        }

        var host = string.IsNullOrWhiteSpace(_host) ? null : _host.Trim();
        var payload = new MxPayload(_domain.Trim(), host, pref);
        var isNew = Existing == null;
        var row = isNew
            ? new DnsRecordRow(
                Id: $"{DnsmasqConfKeys.MxHost}:new",
                OccurrenceId: $"{DnsmasqConfKeys.MxHost}:new",
                OptionName: DnsmasqConfKeys.MxHost,
                Family: DnsRecordFamily.Mx,
                IndexInOption: -1,
                RawValue: "",
                Source: null,
                SourcePath: null,
                SourceLabel: null,
                IsDraftOnly: false,
                IsEditable: true,
                Payload: payload,
                Issues: [],
                Summary: "")
            : Existing! with { Payload = payload };

        await OnSave.InvokeAsync(new DnsRecordEditorResult(row, isNew));
    }
}
