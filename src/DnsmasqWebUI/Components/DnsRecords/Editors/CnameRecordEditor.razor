@using DnsmasqWebUI.Infrastructure.Services.EffectiveConfig.Metadata
<h4 class="h6 mb-2">CNAME</h4>
<div class="row g-2 align-items-end">
    <div class="col-md-4">
        <label class="form-label small mb-0">Aliases (comma-separated)</label>
        <input class="form-control form-control-sm" @bind="_aliases" @bind:event="oninput" />
    </div>
    <div class="col-md-4">
        <label class="form-label small mb-0">Target</label>
        <input class="form-control form-control-sm" @bind="_target" @bind:event="oninput" />
    </div>
    <div class="col-md-2">
        <label class="form-label small mb-0">TTL (optional)</label>
        <input class="form-control form-control-sm" type="number" min="1" @bind="_ttl" @bind:event="oninput" />
    </div>
    <div class="col-md-2 d-flex gap-1">
        <button type="button" class="btn btn-sm btn-primary" @onclick="SaveAsync">Save</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="OnCancel">Cancel</button>
    </div>
</div>
@if (_error != null)
{
    <p class="text-danger small mt-2 mb-0">@_error</p>
}

@code {
    [Parameter] public DnsRecordRow? Existing { get; set; }
    [Parameter] public EventCallback<DnsRecordEditorResult> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private string _aliases = "";
    private string _target = "";
    private string _ttl = "";
    private string? _error;
    private string? _boundRowKey;

    protected override void OnParametersSet()
    {
        if (!DnsRecordEditorSyncGuard.ShouldReseedFromExisting(ref _boundRowKey, Existing))
            return;

        if (Existing?.Payload is CnamePayload p)
        {
            _aliases = string.Join(", ", p.Aliases);
            _target = p.Target;
            _ttl = p.Ttl?.ToString() ?? "";
        }
        else
        {
            _aliases = "";
            _target = "";
            _ttl = "";
        }

        _error = null;
    }

    private async Task SaveAsync()
    {
        _error = null;
        var parts = _aliases.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList();
        if (parts.Count == 0 || string.IsNullOrWhiteSpace(_target))
        {
            _error = "At least one alias and a target are required.";
            return;
        }

        int? ttl = null;
        if (!string.IsNullOrWhiteSpace(_ttl))
        {
            if (!int.TryParse(_ttl, out var t) || t <= 0)
            {
                _error = "TTL must be a positive integer.";
                return;
            }

            ttl = t;
        }

        var payload = new CnamePayload(parts, _target.Trim(), ttl);
        var isNew = Existing == null;
        var row = isNew
            ? new DnsRecordRow(
                Id: $"{DnsmasqConfKeys.Cname}:new",
                OptionName: DnsmasqConfKeys.Cname,
                Family: DnsRecordFamily.Cname,
                IndexInOption: -1,
                RawValue: "",
                Source: null,
                IsEditable: true,
                Payload: payload,
                Issues: [],
                Summary: "")
            : Existing! with { Payload = payload };

        await OnSave.InvokeAsync(new DnsRecordEditorResult(row, isNew));
    }
}
