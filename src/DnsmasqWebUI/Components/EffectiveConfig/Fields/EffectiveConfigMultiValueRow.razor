@namespace DnsmasqWebUI.Components.EffectiveConfig
@using DnsmasqWebUI.Models.Dnsmasq
@using DnsmasqWebUI.Models.Dnsmasq.EffectiveConfig

<li class="ec-field ec-field--multi-value @(Context.IsActiveEditor ? "ec-field-editing" : "")">
    <div class="ec-field-label-row">
        <OptionHelpLabel AnchorId="@(OptionHelpAnchorId ?? "")" HelpKey="@OptionHelpKey" OptionLabel="@Context.Descriptor.OptionName" Title="@LabelTooltip"><strong>@Context.Descriptor.OptionName:</strong></OptionHelpLabel>
        @if (Context.IsActiveEditor || Context.ShowEditableBadge)
        {
            <OptionStateBadge AnchorId="@(ReadonlyBadgeAnchorIdBase ?? "")" Source="@(Context.IsActiveEditor ? Context.RowSource : null)" OptionName="@Context.Descriptor.OptionName" Value="@Context.EffectiveItems"
                IsInteractive="@Context.IsEditMode" ShowEditableBadge="@Context.ShowEditableBadge" HasPendingChange="@Context.HasPendingOrDraft"
                EditableAsButton="true" FieldKey="@Context.FieldKey" IsActiveEditor="@Context.IsActiveEditor"
                IsCapabilityDisabled="@Context.Descriptor.IsCapabilityDisabled" CapabilityDisabledReason="@Context.Descriptor.CapabilityDisabledReason"
                OnConfirmRequested="@OnConfirmRequested" OnCancelRequested="@OnCancelRequested" OnRevertRequested="@OnRevertRequested" />
        }
    </div>
    @if (Context.IsActiveEditor)
    {
        <EffectiveConfigMultiValueListEditor
            SourceItems="@(Context.EffectiveItems)"
            OptionName="@Context.Descriptor.OptionName"
            ReadonlyBadgeAnchorIdBase="@(ReadonlyBadgeAnchorIdBase ?? "")"
            IsEditMode="@Context.IsEditMode"
            AllowAddManagedValue="@Context.IsEditMode"
            FieldKey="@Context.FieldKey"
            Behavior="@(MultiDesc?.Behavior)"
            Validator="@(MultiDesc?.Validator)"
            OnValuesChanged="@ItemsChanged" />
    }
    else
    {
        <div class="ec-field-value ec-field-value-multi">
            <ol class="ec-field-value-list">
                @if (Context.EffectiveItems.Count > 0)
                {
                    @foreach (var (item, index) in Context.EffectiveItems.Select((item, index) => (item, index)))
                    {
                        var anchorId = ReadonlyBadgeAnchorIdBase != null
                            ? $"{ReadonlyBadgeAnchorIdBase}-{index}"
                            : "";
                        <li>
                            <EffectiveConfigMultiValueItem
                                Value="@item.Value"
                                Source="@item.Source"
                                OptionName="@Context.Descriptor.OptionName"
                                IsEditMode="@Context.IsEditMode"
                                ReadonlyBadgeAnchorId="@anchorId"
                                FieldKey="@Context.FieldKey" />
                        </li>
                    }
                }
                else if (Context.EffectiveItems.Count == 0)
                {
                    <li class="ec-multi-list-empty-hint">
                        <span class="text-muted">(none)</span>
                    </li>
                }
            </ol>
        </div>
    }
</li>

@code {
    [Parameter] public EffectiveConfigMultiDisplayContext Context { get; set; } = null!;
    [Parameter] public string? LabelTooltip { get; set; }
    [Parameter] public string? OptionHelpKey { get; set; }
    [Parameter] public string? OptionHelpAnchorId { get; set; }
    [Parameter] public string? ReadonlyBadgeAnchorIdBase { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<string>> ItemsChanged { get; set; }
    [Parameter] public EventCallback OnConfirmRequested { get; set; }
    [Parameter] public EventCallback OnCancelRequested { get; set; }
    [Parameter] public EventCallback OnRevertRequested { get; set; }

    private EffectiveMultiValueConfigFieldDescriptor? MultiDesc =>
        Context.Descriptor as EffectiveMultiValueConfigFieldDescriptor;
}
