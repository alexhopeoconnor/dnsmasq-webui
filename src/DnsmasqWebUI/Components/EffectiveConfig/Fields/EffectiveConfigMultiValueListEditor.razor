@namespace DnsmasqWebUI.Components.EffectiveConfig
@using DnsmasqWebUI.Models.Dnsmasq
@using DnsmasqWebUI.Models.Dnsmasq.EffectiveConfig
@using Microsoft.AspNetCore.Components.Web
@using DnsmasqWebUI.Infrastructure.Services.EffectiveConfig.Validation
@using DnsmasqWebUI.Infrastructure.Services.UI.Notifications.Abstractions
@inject INotificationService NotificationService

<div class="ec-field-value ec-field-value-multi ec-multi-list-editor" @onclick:stopPropagation="true">
    <ol class="ec-field-value-list">
        @if (_displayItems.Count > 0)
        {
            @for (var i = 0; i < _displayItems.Count; i++)
            {
                var item = _displayItems[i];
                var anchorId = $"{ReadonlyBadgeAnchorIdBase}-{i}";
                var itemReadonly = item.Source?.IsReadOnly == true;
                var rowIndex = i;
                var rowValue = item.Value;

                <li class="ec-multi-list-row @(_editingIndex == rowIndex && !itemReadonly ? "ec-multi-list-row-with-controls" : "")" @key="anchorId">
                    <div class="ec-multi-list-row-body">
                        @if (_editingIndex == rowIndex && !itemReadonly)
                        {
                            <div class="ec-multi-list-row-controls">
                                <div class="ec-multi-list-input-group">
                                    <input class="form-control form-control-sm ec-multi-list-input"
                                           placeholder="@(DnsmasqOptionPlaceholders.Get(OptionName) ?? "Value")"
                                           @bind="_draftValue" @bind:event="oninput" />
                                </div>
                                <span class="status-badge-inline">
                                    <StatusBadge Kind="StatusBadgeKind.ActionOk" Text="save" Clickable="true"
                                                 Title="Apply change" AriaLabel="Apply change"
                                                 PreventBlurOnMouseDown="true" OnClick="@(() => SaveEdit(rowIndex))" Class="status-badge-inline" />
                                    <StatusBadge Kind="StatusBadgeKind.ActionCancel" Text="cancel" Clickable="true"
                                                 Title="Discard edit" AriaLabel="Cancel edit"
                                                 PreventBlurOnMouseDown="true" OnClick="CancelInline" Class="status-badge-inline" />
                                </span>
                            </div>
                        }
                        else
                        {
                            <span class="ec-field-value-item">@rowValue</span>

                            <span class="status-badge-inline">
                                <OptionStateBadge
                                    AnchorId="@anchorId"
                                    Source="@item.Source"
                                    OptionName="@OptionName"
                                    Value="@rowValue"
                                    IsInteractive="@IsEditMode"
                                    ShowEditableBadge="@(!itemReadonly)"
                                    EditableAsButton="@(!itemReadonly)"
                                    OnEditableClickRequested="@(!itemReadonly ? EventCallback.Factory.Create(this, () => { BeginEdit(rowIndex, rowValue); return Task.CompletedTask; }) : default)" />
                                @if (!itemReadonly)
                                {
                                    <StatusBadge Kind="StatusBadgeKind.ActionRevert" Text="remove" Clickable="true"
                                                 Title="Remove this value" AriaLabel="Remove"
                                                 PreventBlurOnMouseDown="true"
                                                 OnClick="@(() => RemoveAt(rowIndex))" Class="status-badge-inline" />
                                }
                            </span>
                        }
                    </div>
                </li>
            }
        }
        else if (!AllowAddManagedValue)
        {
            <li class="ec-multi-list-row ec-multi-list-empty-hint">
                <span class="text-muted">(none)</span>
            </li>
        }

        @if (AllowAddManagedValue)
        {
            <li class="ec-multi-list-row ec-multi-list-add-item @(_addingNew ? "ec-multi-list-row-with-controls" : "")" @key="AddItemKey">
                @if (_addingNew)
                {
                    <div class="ec-multi-list-row-controls">
                        <div class="ec-multi-list-input-group">
                            <input @ref="_addNewInputRef" class="form-control form-control-sm ec-multi-list-input"
                                   placeholder="@(DnsmasqOptionPlaceholders.Get(OptionName) ?? "Value")"
                                   @bind="_draftValue" @bind:event="oninput" />
                        </div>
                        <span class="status-badge-inline">
                            <StatusBadge Kind="StatusBadgeKind.ActionOk" Text="add" Clickable="true"
                                         Title="Add this value" AriaLabel="Add"
                                         PreventBlurOnMouseDown="true" OnClick="SaveNew" Class="status-badge-inline" />
                            <StatusBadge Kind="StatusBadgeKind.ActionCancel" Text="cancel" Clickable="true"
                                         Title="Discard" AriaLabel="Cancel"
                                         PreventBlurOnMouseDown="true" OnClick="CancelInline" Class="status-badge-inline" />
                        </span>
                    </div>
                }
                else
                {
                    <StatusBadge Kind="StatusBadgeKind.Editable" Text="add item" Clickable="true"
                                 Title="Add a new value" AriaLabel="Add item"
                                 OnClick="BeginAdd" Class="status-badge-inline ec-multi-list-add-btn" />
                }
            </li>
        }
    </ol>
</div>

@code {
    [Parameter] public IReadOnlyList<ValueWithSource>? SourceItems { get; set; }
    [Parameter] public string OptionName { get; set; } = "";
    [Parameter] public string ReadonlyBadgeAnchorIdBase { get; set; } = "";

    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public bool AllowAddManagedValue { get; set; } = true;

    [Parameter] public IMultiValueEditBehavior? Behavior { get; set; }
    [Parameter] public IMultiValueOptionValidator? Validator { get; set; }
    [Parameter] public string? FieldKey { get; set; }

    [Parameter] public EventCallback<IReadOnlyList<string>> OnValuesChanged { get; set; }

    private const string AddItemKey = "add-item";
    private static readonly TimeSpan ValidationToastDedupeWindow = TimeSpan.FromSeconds(2);

    private int? _editingIndex;
    private bool _addingNew;
    private string _draftValue = "";
    private bool _didAutoOpenAdd;
    private bool _shouldFocusAddInput;
    private ElementReference _addNewInputRef;
    private string? _lastValidationErrorMessage;
    private DateTime _lastValidationErrorUtc;

    private List<ValueWithSource> _displayItems = new();
    private IReadOnlyList<string> _currentValues => _displayItems.Select(x => x.Value).ToList();

    protected override void OnParametersSet()
    {
        _displayItems = (SourceItems ?? Array.Empty<ValueWithSource>()).ToList();

        if (!_didAutoOpenAdd && (SourceItems?.Count ?? 0) == 0 && AllowAddManagedValue)
        {
            _didAutoOpenAdd = true;
            _addingNew = true;
            _shouldFocusAddInput = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocusAddInput && _addingNew)
        {
            _shouldFocusAddInput = false;
            try
            {
                await _addNewInputRef.FocusAsync();
            }
            catch
            {
                // Focus can fail if the element is not yet in the DOM (e.g. prerender)
            }
        }
    }

    private void BeginEdit(int index, string current)
    {
        _addingNew = false;
        _editingIndex = index;
        _draftValue = current;
    }

    private void BeginAdd()
    {
        _editingIndex = null;
        _addingNew = true;
        _draftValue = "";
        _shouldFocusAddInput = true;
    }

    private void CancelInline()
    {
        _editingIndex = null;
        _addingNew = false;
        _draftValue = "";
        _lastValidationErrorMessage = null;
    }

    private void ShowValidationError(string message)
    {
        var now = DateTime.UtcNow;
        if (string.Equals(_lastValidationErrorMessage, message, StringComparison.Ordinal) &&
            (now - _lastValidationErrorUtc) < ValidationToastDedupeWindow)
            return;
        _lastValidationErrorMessage = message;
        _lastValidationErrorUtc = now;
        NotificationService.ShowError(message);
    }

    private async Task SaveEdit(int index)
    {
        var current = _currentValues;
        var next = current.ToList();
        if (index < 0 || index >= next.Count) return;

        var raw = _draftValue ?? "";
        var normalized = Behavior?.Normalize(raw) ?? raw.Trim();
        if (normalized.Length == 0)
        {
            ShowValidationError("Value cannot be empty.");
            return;
        }

        var validationError = Validator?.ValidateItem(normalized, current, index);
        if (validationError != null)
        {
            ShowValidationError(validationError);
            return;
        }

        if (Behavior?.AllowDuplicates == false && next.Where((v, i) => i != index).Any(v => string.Equals(v, normalized, StringComparison.Ordinal)))
        {
            ShowValidationError("Duplicate values are not allowed.");
            return;
        }

        next[index] = normalized;
        _displayItems[index] = _displayItems[index] with { Value = normalized };
        await OnValuesChanged.InvokeAsync(next);
        CancelInline();
    }

    private async Task SaveNew()
    {
        var raw = _draftValue ?? "";
        var normalized = Behavior?.Normalize(raw) ?? raw.Trim();
        if (normalized.Length == 0)
        {
            ShowValidationError("Value cannot be empty.");
            return;
        }

        var current = _currentValues;
        var validationError = Validator?.ValidateItem(normalized, current, null);
        if (validationError != null)
        {
            ShowValidationError(validationError);
            return;
        }

        if (Behavior?.AllowDuplicates == false && current.Contains(normalized, StringComparer.Ordinal))
        {
            ShowValidationError("Duplicate values are not allowed.");
            return;
        }

        var next = current.ToList();
        next.Add(normalized);
        _displayItems.Add(new ValueWithSource(normalized, null));
        await OnValuesChanged.InvokeAsync(next);
        CancelInline();
    }

    private async Task RemoveAt(int index)
    {
        if (index < 0 || index >= _displayItems.Count) return;
        var item = _displayItems[index];
        if (item?.Source?.IsReadOnly == true) return;

        var next = _displayItems.Select(x => x.Value).ToList();
        if (index < 0 || index >= next.Count) return;

        next.RemoveAt(index);
        _displayItems.RemoveAt(index);
        await OnValuesChanged.InvokeAsync(next);
        StateHasChanged();
    }
}
