@namespace DnsmasqWebUI.Components.Shared
@using DnsmasqWebUI.Infrastructure.Services.UI.Notifications.Abstractions
@inject INotificationService NotificationService

<button type="button"
        class="btn btn-link btn-sm text-muted p-0 ms-1 align-middle border-0"
        title="@HelpText"
        aria-label="@HelpText"
        @onclick="OnClick"
        @onclick:stopPropagation="true">
    <i class="bi bi-question-circle" aria-hidden="true"></i>
</button>

@code {
    [Parameter, EditorRequired] public string HelpText { get; set; } = "";

    private void OnClick() => NotificationService.ShowInfo(HelpText);
}
